# Datadog RUM configuration (all optional — sensible defaults are used).
# Copy to `.env.local` and override as needed. These are build-time vars,
# inlined into the client bundle by Vite, so do NOT put secrets here.

# Service name shown in Datadog RUM
VITE_DD_SERVICE=bill-splitter

# Environment tag: prod | staging | dev
VITE_DD_ENV=prod

# Release version tag
VITE_DD_VERSION=0.1.0
